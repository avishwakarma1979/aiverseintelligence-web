---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'AiVerse Intelligence — AI systems for the Indian markets',
  description = 'AiVerse Intelligence is a research lab building AI co-pilots for Indian retail traders. StockAiVerse is our first product.',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate icon" href="/aiverse-logo.jpeg" />
    <link rel="apple-touch-icon" href="/aiverse-logo.jpeg" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content="/aiverse-logo.jpeg" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="/aiverse-logo.jpeg" />

    <meta name="theme-color" content="#0A0A0B" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    {import.meta.env.PUBLIC_POSTHOG_KEY && (
      <script define:vars={{ phKey: import.meta.env.PUBLIC_POSTHOG_KEY, phHost: import.meta.env.PUBLIC_POSTHOG_HOST || "https://us.posthog.com" }}>
        !function(t,e){var o,n,p,r;e.__SV||(window.posthog=e,e._i=[],e.init=function(i,s,a){function g(t,e){var o=e.split(".");2==o.length&&(t=t[o[0]],e=o[1]);t[e]=function(){t.push([e].concat(Array.prototype.slice.call(arguments,0)))}}(p=t.createElement("script")).type="text/javascript",p.crossOrigin="anonymous",p.async=!0,p.src=s.api_host.replace(".i.posthog.com","posthog.com")+"/static/array.js",(r=t.getElementsByTagName("script")[0]).parentNode.insertBefore(p,r);var u=e;for(void 0!==a?u=e[a]=[]:a="posthog",u.people=u.people||[],u.toString=function(t){var e="posthog";return"posthog"!==a&&(e+="."+a),t||(e+=" (stub)"),e},u.people.toString=function(){return u.toString()+" (stub)"},o="init me ws ys ps bs capture register register_once register_for_session unregister opt_out_capturing opt_in_capturing has_opted_out_capturing has_opted_in_capturing get_distinct_id alias set_config startSessionRecording stopSessionRecording sessionRecordingStarted captureException loadToolbar get_property getFeatureFlag getFeatureFlagPayload isFeatureEnabled reloadFeatureFlags updateEarlyAccessFeatureEnrollment getEarlyAccessFeatures on onFeatureFlags onSessionId getSurveys getActiveMatchingSurveys renderSurvey canRenderSurvey identify setPersonProperties group resetGroups setPersonPropertiesForFlags resetPersonPropertiesForFlags setGroupPropertiesForFlags resetGroupPropertiesForFlags reset get_session_id get_session_replay_url".split(" "),n=0;n<o.length;n++)g(u,o[n]);e._i.push([i,s,a])},e.__SV=1)}(document,window.posthog||[]);
        posthog.init(phKey, {
          api_host: phHost,
          capture_pageview: true,
          capture_pageleave: true,
          autocapture: false,
          mask_all_text: false,
          session_recording: { maskAllInputs: true },
        });
        document.addEventListener("click", function(e) {
          var a = e.target.closest("a");
          if (!a || !a.href) return;
          var dest = a.href;
          try {
            var url = new URL(a.href);
            if (url.hostname === window.location.hostname) return;
            e.preventDefault();
            if (url.hostname.indexOf("stockaiverse.com") !== -1) {
              url.searchParams.set("utm_source", "aiverseintelligence");
              url.searchParams.set("utm_medium", "referral");
              try { url.searchParams.set("ph_distinct_id", posthog.get_distinct_id()); } catch(_) {}
            }
            dest = url.toString();
          } catch(_) {}
          // PostHog capture isolated — never blocks navigation
          try {
            posthog.capture("outbound_link_clicked", {
              url: a.href, dest: dest,
              text: (a.textContent || "").trim().slice(0, 80),
              from_path: window.location.pathname,
            });
          } catch(_) {}
          setTimeout(function() {
            if (a.target === "_blank") { window.open(dest, "_blank"); }
            else { window.location.href = dest; }
          }, 150);
        }, true);
      </script>
    )}

    {import.meta.env.PUBLIC_CLARITY_PROJECT_ID && (
      <script define:vars={{ clarityId: import.meta.env.PUBLIC_CLARITY_PROJECT_ID }}>
        (function(c,l,a,r,i,t,y){c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y)})(window,document,"clarity","script",clarityId);
      </script>
    )}
  </head>
  <body>
    <slot />
  </body>
</html>
